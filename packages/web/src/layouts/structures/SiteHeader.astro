---

---
<header id="site-header" class="sticky top-0 p-4 backdrop-blur-xs bg-background/75">
	<div class="container mx-auto flex items-center justify-between">
		<h1 class="text-base flex flex-row items-center gap-1 font-monospace text-foreground dark:text-muted before:inline-block before:bg-muted before:h-[1.5px] before:rounded-full before:w-3 after:inline-block after:bg-accent-500 after:h-[1.5px] after:w-3 after:rounded-full">
		  crushing
			<span class="text-accent-500 -ml-0.5">viz</span>
		</h1>
		<div id="theme-selector" class="inline-flex items-center rounded-full border border-border p-0.5 gap-0.5" role="radiogroup" aria-label="Color scheme">
			<button id="light-option" role="radio" aria-checked="false" aria-label="Light mode" class="px-1.5 py-0.5 rounded-full transition-colors cursor-pointer">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
				</svg>
			</button>
			<button id="dark-option" role="radio" aria-checked="false" aria-label="Dark mode" class="px-1.5 py-0.5 rounded-full transition-colors cursor-pointer">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
					<path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
				</svg>
			</button>
		</div>
	</div>
</header>
<script>
import type { WindowExtended } from "../PageLayout.astro";

const lightOption = document.getElementById("light-option");
const darkOption = document.getElementById("dark-option");

// const selectedClasses = ["bg-muted", "text-accent-500"];
const unselectedClasses = ["text-muted", "hover:text-foreground"];

const colorSchemeManager = (window as unknown as WindowExtended).colorSchemeManager;
function updateSelector() {
	const scheme = colorSchemeManager.getColorScheme();
	const [buttonToActivate, buttonToDeactivate] = scheme === "dark" ? [darkOption, lightOption] : [lightOption, darkOption];

	buttonToDeactivate?.setAttribute("aria-checked", "false");
	buttonToActivate?.setAttribute("aria-checked", "true");
}

// Initial state
updateSelector();

// Switch on click
lightOption?.addEventListener("click", () => {
	colorSchemeManager.setPreference("light");
});

darkOption?.addEventListener("click", () => {
	colorSchemeManager.setPreference("dark");
});

// Subscribe to changes from other sources
colorSchemeManager.subscribe(updateSelector);
</script>
<style>
@reference "../../styles/global.css";

#theme-selector button {
  @apply text-muted;
  @apply hover:text-foreground;
}

#theme-selector button[aria-checked="true"] {
  @apply text-accent-500;
  @apply cursor-auto;
}
</style>
